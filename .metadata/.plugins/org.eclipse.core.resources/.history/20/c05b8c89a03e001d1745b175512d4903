package classe_e_atributo;

import java.util.Scanner;

public class Ex53W {

	public static void main(String[] args) {
		Scanner ler = new Scanner(System.in);
		Aluno[] listaaluno = new Aluno[2];
		
		int i = 0;
		
		
		while(i <= 1) {
			Aluno a = new Aluno();
			
			System.out.print("Digite o RA escolar: ");
			a.ra = ler.next();
			
			System.out.print("Digite o nome do aluno: ");
			a.nome = ler.next();
			
			String[] listamateria = new String[6];
			
			for(int b=0; b<=5; b++) {
			System.out.print("Digite a sigla inicial das 6 materias: ");
			listamateria[b] = ler.next();
			}
			a.materias = listamateria;
			
			System.out.print("Insira o periodo escolar: ");
			a.periodo = ler.next();
			
			listaaluno[i] = a;
			i++;
		}
		
		for(int i=0; i<=1; i++) {
			if (listaaluno[i].periodo.equals("noite")) {
				System.out.print("ra: " + listaaluno[i].ra);
				System.out.print("Nome: " + listaaluno[i].nome);
				System.out.print("Materias: " + listaaluno[i].materias);
				System.out.print("Periodo: " + listaaluno[i].periodo);
				
			}
		}

	}

}
