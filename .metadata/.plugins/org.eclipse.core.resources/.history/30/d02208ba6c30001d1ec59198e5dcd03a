package entrada_processamento_saida;

import java.util.Scanner;

public class Ex38 {

	public static void main(String[] args) {
		Scanner ler = new Scanner(System.in);
		
		int v, i, r;
		
		System.out.printf("Digite o valor a ser somado: ");
		v = ler.nextInt();
		
		while (v < 0) {
			System.out.printf("Números negativos não são permitidos.\n Digite novamente: ");
			v = ler.nextInt();
		}
		i = 1;
		
		while (i <= 100) {
			r = v + i;
			System.out.printf("\n%d + %d = %d", v, i, r);
			i = i + 1;
		}

	}

}
