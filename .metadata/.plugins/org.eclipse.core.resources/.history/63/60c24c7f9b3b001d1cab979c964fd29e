package classe_e_atributo;

import java.util.Scanner;

public class Ex51 {

	public static void main(String[] args) {
		Scanner ler = new Scanner(System.in);
		
		cliente [] listaclientes = new cliente[5];
		
		System.out.println("..::Cadastro de Clientes::..");
		
		for (int i=1; i<=5; i++) {
			cliente c = new cliente();
			
			System.out.print("Digite o ID: ");
			c.id = ler.nextInt();
			
			System.out.print("Digite a idade: ");
			c.idade = ler.nextInt();
			
			
			listaclientes[i] = c;
		}
		
		System.out.print("Os cliente acima de 18 anos são:\n");
		
		for (int i=1; i<=5; i++) {
			System.out.print("ID" + listaclientes[i].id);
			System.out.print("Idade" + listaclientes[i].idade);
		}

	}

}
