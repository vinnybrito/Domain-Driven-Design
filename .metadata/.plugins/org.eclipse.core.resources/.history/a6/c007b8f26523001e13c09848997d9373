package A03_Estruturas_de_Repeticao;

import java.util.Scanner;

public class Ex37W {

	public static void main(String[] args) {
		Scanner read = new Scanner(System.in);
		
		int j = 1, i = 1, r;
		
		while (j <= 20) {
			
			while (i <= 10) {
				r = j * i;
				System.out.printf("\n%d X %d = %d", j, i, r);
				i += 1;
			}
			
			System.out.printf("\nAperte qualquer tecla...");
			read.nextLine();
			
			j += 1;
		}
		
		System.out.printf("\nFim da tabuada.");
	}

}
