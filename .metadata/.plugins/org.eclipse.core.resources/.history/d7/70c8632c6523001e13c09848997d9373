package A03_Estruturas_de_Repeticao;

import java.util.Scanner;

public class Ex37W {

	public static void main(String[] args) {
		Scanner read = new Scanner(System.in);
		
		int j, i, r;
		
		for (j = 1; j <= 20; j++) {
			
			for (i = 1; i <= 10; i++) {
				r = j * i;
				System.out.printf("\n%d X %d = %d", j, i, r);
			}
			
			System.out.printf("Aperte qualquer tecla...");
			read.nextLine();
		}
		
		System.out.printf("Fim da tabuada.");
	}

}
